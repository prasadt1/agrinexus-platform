{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerReadOnly",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:043624892076:secret:Stripe-Secret-*",
        "arn:aws:secretsmanager:us-east-1:043624892076:secret:agrinexus/weather/api-key-*"
      ]
    },
    {
      "Sid": "DynamoDBControlPlaneReads",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:BatchGetItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data",
        "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data/index/GSI1",
        "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data/index/GSI2"
      ]
    },
    {
      "Sid": "DynamoDBControlPlaneWrites",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data"
      ]
    },
    {
      "Sid": "StepFunctionsDemoTrigger",
      "Effect": "Allow",
      "Action": [
        "states:StartExecution"
      ],
      "Resource": [
        "arn:aws:states:us-east-1:043624892076:stateMachine:agrinexus-nudge-workflow-dev"
      ]
    }
  ]
}
