{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadMembership",
      "Effect": "Allow",
      "Action": "dynamodb:GetItem",
      "Resource": "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data",
      "Condition": {
        "ForAllValues:StringLike": {
          "dynamodb:LeadingKeys": ["PHONE#*"]
        }
      }
    },
    {
      "Sid": "WriteSummary",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem", "dynamodb:UpdateItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data",
      "Condition": {
        "ForAllValues:StringLike": {
          "dynamodb:LeadingKeys": ["TENANT#*"]
        }
      }
    },
    {
      "Sid": "WriteDedupeMarker",
      "Effect": "Allow",
      "Action": "dynamodb:PutItem",
      "Resource": "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data",
      "Condition": {
        "ForAllValues:StringLike": {
          "dynamodb:LeadingKeys": ["DEDUPE#*"]
        }
      }
    },
    {
      "Sid": "ReadStream",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetRecords",
        "dynamodb:GetShardIterator",
        "dynamodb:DescribeStream",
        "dynamodb:ListStreams"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:043624892076:table/agrinexus-data/stream/*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:043624892076:log-group:/aws/lambda/agrinexus-outcomes-aggregator-dev:*"
    }
  ]
}
