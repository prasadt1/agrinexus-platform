# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
dist/
public/logo/

# private working/strategy/planning docs — for my eyes only, not public
docs/

# heavy media — never check video/audio/archives/design sources into the public repo.
# Article/README images live (tracked) under public/; raw drafts live under docs/ (ignored).
*.mp4
*.mov
*.m4a
*.wav
*.mp3
*.aac
*.zip
*.psd
*.ai
*.sketch
*.fig
