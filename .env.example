# =============================================================================
# Secrets strategy: AWS Secrets Manager is the source of truth.
#
# Only the BOOTSTRAP AWS credentials + non-sensitive config live here / in
# Vercel env vars (you need them to authenticate to AWS in the first place).
# All application secrets (Stripe keys, weather API key) are read from
# AWS Secrets Manager at runtime. The env vars below for those are LOCAL-DEV
# FALLBACKS ONLY, used when Secrets Manager is unreachable.
# =============================================================================

# --- Bootstrap AWS credentials (Vercel env vars; cannot live in Secrets Manager) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: Session token if using temporary credentials
# AWS_SESSION_TOKEN=your-session-token

# --- Non-sensitive config ---
DYNAMODB_TABLE_NAME=agrinexus-data
AWS_ACCOUNT_ID=043624892076
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Application secrets — SOURCE OF TRUTH: AWS Secrets Manager
# =============================================================================
#
# Secret `Stripe-Secret` (JSON):
#   {
#     "secretKey": "sk_test_...",
#     "priceIds": {
#       "starter": "price_...",
#       "growth": "price_...",
#       "enterprise": "price_..."
#     }
#   }
#
# Secret `agrinexus/weather/api-key` (plain string):
#   <openweathermap-api-key>
#
# Local-dev fallbacks (only used if Secrets Manager returns nothing):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_PRICE_ID=price_...        # fallback for all tiers
# WEATHER_API_KEY=...
